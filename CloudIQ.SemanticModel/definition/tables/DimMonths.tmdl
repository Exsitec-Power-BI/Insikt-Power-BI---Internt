	partition DimMonths = calculated
		mode: import
		source = ```
				
				SUMMARIZE (
				    // Start with a distinct list of YearMonth values from your fact table
				    DISTINCT ( 'LH_CloudIQ OLD'[YearMonth] ),
				    
				    // Add the columns you need for the hierarchy
				    'LH_CloudIQ OLD'[YearMonth],
				    "Year", VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ),
				    "MonthNo", VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ),
				    "QuarterNo", FORMAT ( DATE ( VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ), VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ), 1 ), "q" ),
				    "Quarter", "Q" & FORMAT ( DATE ( VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ), VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ), 1 ), "q" ),
				    "Month", FORMAT ( DATE ( VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ), VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ), 1 ), "mmmm" ),
				
				    "QuarterYear", FORMAT ( DATE ( VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ), VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ), 1 ), "yyyy" ) & " Q" & FORMAT ( DATE ( VALUE ( LEFT ( 'LH_CloudIQ OLD'[YearMonth], 4 ) ), VALUE ( RIGHT ( 'LH_CloudIQ OLD'[YearMonth], 2 ) ), 1 ), "q" )
				)
				```

	annotation PBI_Id = 6f2123d020f64d089aa71aa164d55619

